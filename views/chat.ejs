<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SoulAI - Premium Deep Connections</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --accent-pink: #ff477e;
            --accent-hover: #ff1a5c;
            --gold: #f1c40f;
            --chat-bg: #0f1016;
            --card-dark: #171923;
            --text-light: #ffffff;
            --text-muted: #94a3b8;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: -apple-system, sans-serif; }
        body { background-color: var(--chat-bg); color: var(--text-light); height: 100vh; overflow: hidden; display: flex; flex-direction: column; }
        
        .auth-screen { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 1.5rem; width: 100%; position: fixed; top:0; left:0; background: var(--chat-bg); z-index: 10000; }
        .auth-container { background: var(--card-dark); padding: 2.5rem 2rem; border-radius: 24px; max-width: 400px; width: 100%; border: 1px solid rgba(255,255,255,0.05); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .auth-brand { text-align: center; margin-bottom: 2rem; }
        .auth-brand i { font-size: 3rem; color: var(--accent-pink); margin-bottom: 0.5rem; }
        .form-group { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.25rem; }
        .form-group label { font-size: 0.85rem; color: var(--text-muted); font-weight: 500; }
        .form-group input { padding: 0.85rem 1.25rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); background: #222533; color: white; font-size: 1rem; outline: none; }
        .btn-auth { background: var(--accent-pink); color: white; border: none; padding: 1rem; border-radius: 12px; font-weight: bold; width: 100%; cursor: pointer; }
        .toggle-link { text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: var(--text-muted); }
        .toggle-link span { color: var(--accent-pink); cursor: pointer; font-weight: bold; }
        .error-msg { color: #e74c3c; background: rgba(231, 76, 60, 0.1); padding: 0.75rem; border-radius: 8px; font-size: 0.85rem; text-align: center; margin-bottom: 1rem; display: none; }

        .nav-tabs { display: flex; background: var(--card-dark); border-bottom: 1px solid rgba(255,255,255,0.05); }
        .tab-btn { flex: 1; padding: 1rem; text-align: center; background: none; border: none; color: var(--text-muted); font-weight: bold; cursor: pointer; }
        .tab-btn.active { color: var(--accent-pink); border-bottom: 3px solid var(--accent-pink); }
        
        .view-section { display: none; flex: 1; flex-direction: column; overflow-y: auto; }
        .view-section.active { display: flex; }

        .top-bar { padding: 1rem; background: var(--card-dark); display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .profile-meta { display: flex; align-items: center; gap: 1rem; }
        .avatar { width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg, #ff758f, #ff477e); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
        .status-dot { width: 8px; height: 8px; background: #2ecc71; border-radius: 50%; display: inline-block; margin-right: 4px; }
        .logout-btn { background: none; border: none; color: var(--text-muted); font-size: 0.9rem; cursor: pointer; }

        .chat-area { flex: 1; padding: 1.5rem; overflow-y: auto; display: flex; flex-direction: column; gap: 1rem; }
        .msg { max-width: 80%; padding: 0.85rem 1.15rem; border-radius: 20px; line-height: 1.45; font-size: 0.95rem; }
        .user-msg { background: var(--accent-pink); color: white; align-self: flex-end; border-bottom-right-radius: 4px; }
        .ai-msg { background: var(--card-dark); color: #f1f5f9; align-self: flex-start; border-bottom-left-radius: 4px; border: 1px solid rgba(255,255,255,0.05); }
        
        .typing-indicator { display: none; background: var(--card-dark); align-self: flex-start; padding: 0.85rem 1.15rem; border-radius: 20px; gap: 4px; }
        .typing-dot { width: 6px; height: 6px; background: var(--text-muted); border-radius: 50%; animation: bounce 1.4s infinite ease-in-out both; }
        .typing-dot:nth-child(2) { animation-delay: -0.16s; }
        @keyframes bounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1.0); } }

        .input-bar { padding: 1rem; background: var(--card-dark); display: flex; gap: 0.75rem; align-items: center; }
        .input-bar input { flex: 1; padding: 0.85rem 1.25rem; border-radius: 25px; border: 1px solid rgba(255,255,255,0.1); background: #222533; color: white; outline: none; }
        .btn-send { background: var(--accent-pink); border: none; width: 45px; height: 45px; border-radius: 50%; color: white; cursor: pointer; }

        .match-grid { padding: 1.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        .match-card { background: var(--card-dark); border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); position: relative; cursor: pointer; }
        .match-img { width: 100%; height: 140px; display: flex; align-items: center; justify-content: center; font-size: 2.8rem; }
        .match-info { padding: 0.75rem; }
        .match-badge { position: absolute; top: 10px; right: 10px; background: rgba(15,16,22,0.85); padding: 2px 8px; border-radius: 12px; font-size: 0.75rem; color: var(--gold); font-weight: bold; }

        .pay-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(10, 11, 18, 0.96); justify-content: center; align-items: center; padding: 1.5rem; z-index: 99999; }
        .modal-content { background: var(--card-dark); padding: 2rem; border-radius: 24px; text-align: center; max-width: 380px; border: 1px solid var(--accent-pink); width: 100%; }
        .modal-content i { font-size: 3.5rem; color: var(--gold); margin-bottom: 1rem; }
        .modal-form { margin-top: 1.25rem; text-align: left; display: flex; flex-direction: column; gap: 0.75rem; }
        .modal-form label { font-size: 0.85rem; color: var(--text-muted); }
        .modal-form input { padding: 0.85rem 1rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); background: #222533; color: white; outline: none; }
        .btn-pay-submit { background: linear-gradient(135deg, #2ecc71, #27ae60); color: white; padding: 0.95rem; border: none; border-radius: 12px; font-weight: bold; cursor: pointer; width: 100%; margin-top: 0.5rem; }
    </style>
</head>
<body>

    <% if (!user) { %>
    <div class="auth-screen" id="authScreenBlock">
        <div class="auth-container">
            <div class="auth-brand">
                <i class="fa-solid fa-heart-pulse"></i>
                <h2 id="authTitle">Create Account</h2>
                <p id="authSubtitle" style="color: var(--text-muted); font-size: 0.85rem; margin-top:0.3rem;">Join SoulAI to meet premium models</p>
            </div>
            <div class="error-msg" id="errorBlock"></div>
            <form id="authForm" onsubmit="handleAuthenticationSubmit(event)">
                <div class="form-group" id="phoneGroupField">
                    <label>Safaricom Phone Number (For M-Pesa tracking)</label>
                    <input type="tel" id="authPhoneInput" placeholder="e.g. 0712345678">
                </div>
                <div class="form-group">
                    <label>Username Identity Key</label>
                    <input type="text" id="authUsernameInput" placeholder="username123" required>
                </div>
                <button type="submit" class="btn-auth" id="authBtn">Sign Up Base Account</button>
            </form>
            <div class="toggle-link">
                <p id="toggleText">Already have an account? <span onclick="toggleAuthModeState()">Sign In</span></p>
            </div>
        </div>
    </div>
    <% } %>

    <div class="nav-tabs">
        <button class="tab-btn active" onclick="switchTab('chat-view')"><i class="fa-solid fa-comments"></i> Chat Interface</button>
        <button class="tab-btn" onclick="switchTab('match-view')"><i class="fa-solid fa-heart"></i> Premium Matches (15)</button>
    </div>

    <div id="chat-view" class="view-section active">
        <div class="top-bar">
            <div class="profile-meta">
                <div class="avatar" id="partnerAvatarHeader"><i class="fa-solid fa-venus"></i></div>
                <div>
                    <h4 id="activeChatPartnerLabel">Clara</h4>
                    <span style="font-size: 0.75rem; color: var(--text-muted);"><span class="status-dot"></span>Online Now</span>
                </div>
            </div>
            <button class="logout-btn" onclick="window.location.href='/logout'"><i class="fa-solid fa-right-from-bracket"></i> Logout</button>
        </div>
        
        <div class="chat-area" id="chatBox">
            <div class="msg ai-msg" id="partnerGreetingMsg">Hey there... select me from the Matches tab to unlock our conversation path! 💖</div>
            <div class="typing-indicator" id="typingIndicator">
                <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
            </div>
        </div>

        <div class="input-bar">
            <input type="text" id="userInput" placeholder="Type your premium message..." onkeypress="if(event.key==='Enter') sendChatMessageRoute()">
            <button class="btn-send" onclick="sendChatMessageRoute()"><i class="fa-solid fa-paper-plane"></i></button>
        </div>
    </div>

    <div id="match-view" class="view-section">
        <div class="top-bar"><h4>15 Discovered Premium Models</h4></div>
        <div class="match-grid">
            <script>
                const profiles = [
                    { name: "Clara", age: 23, city: "Nairobi", gender: "woman", icon: "👩‍🦰" },
                    { name: "Ethan", age: 25, city: "Mombasa", gender: "man", icon: "🧔" },
                    { name: "Amani", age: 22, city: "Kisumu", gender: "woman", icon: "👩" },
                    { name: "Ryan", age: 26, city: "Eldoret", gender: "man", icon: "👨‍💼" },
                    { name: "Sarah", age: 24, city: "Nairobi", gender: "woman", icon: "👱‍♀️" },
                    { name: "Alex", age: 27, city: "Nakuru", gender: "man", icon: "👨" },
                    { name: "Stacy", age: 21, city: "Thika", gender: "woman", icon: "👧" },
                    { name: "Caleb", age: 24, city: "Mombasa", gender: "man", icon: "👦" },
                    { name: "Naomi", age: 23, city: "Nairobi", gender: "woman", icon: "🧕" },
                    { name: "Liam", age: 26, city: "Kisumu", gender: "man", icon: "👨‍🎨" },
                    { name: "Faith", age: 22, city: "Kitale", gender: "woman", icon: "👩‍🎓" },
                    { name: "Brandon", age: 25, city: "Eldoret", gender: "man", icon: "🏃‍♂️" },
                    { name: "Joy", age: 24, city: "Malindi", gender: "woman", icon: "👑" },
                    { name: "David", age: 28, city: "Nairobi", gender: "man", icon: "🤵" },
                    { name: "Delilah", age: 22, city: "Naivasha", gender: "woman", icon: "💖" }
                ];

                profiles.forEach((p, index) => {
                    document.write(`
                        <div class="match-card" onclick="selectMatchPartner('${p.name}', '${p.icon}')">
                            <span class="match-badge">${99 - index}% Match</span>
                            <div class="match-img" style="background: ${p.gender === 'woman' ? 'linear-gradient(135deg, #ff758f, #ff477e)' : 'linear-gradient(135deg, #2c3e50, #3498db)'};">${p.icon}</div>
                            <div class="match-info"><h5>${p.name}, ${p.age}</h5><p>${p.city} • Verified Premium Match</p></div>
                        </div>
                    `);
                });
            </script>
        </div>
    </div>

    <div class="pay-modal" id="payModal">
        <div class="modal-content">
            <i class="fa-solid fa-crown"></i>
            <h3>Unlock Deep Conversations</h3>
            <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 0.5rem;">Access rules require a one-time activation value of <b>Ksh 250</b> to unlock unlimited real-time AI processing chats with all 15 models.</p>
            
            <div class="modal-form">
                <label>Registered Mobile Number (Safaricom M-Pesa)</label>
                <input type="tel" id="payPhone" value="<%= user ? user.phone : '' %>"> <label>Account Reference Identity</label>
                <input type="text" id="payName" value="<%= user ? user.username : '' %>" readonly>
            </div>

            <button class="btn-pay-submit" onclick="executePesapalCheckoutFlow()">Pay Ksh 250 via Pesapal</button>
            <button class="logout-btn" style="margin-top: 1rem;" onclick="document.getElementById('payModal').style.display='none'">Cancel Activation</button>
        </div>
    </div>

    <script>
        let currentAuthIsSignUp = true;
        let selectedPartnerName = "Clara";

        function toggleAuthModeState() {
            currentAuthIsSignUp = !currentAuthIsSignUp;
            document.getElementById('errorBlock').style.display = 'none';
            if (currentAuthIsSignUp) {
                document.getElementById('authTitle').textContent = "Create Account";
                document.getElementById('phoneGroupField').style.display = "flex";
                document.getElementById('authBtn').textContent = "Sign Up Base Account";
                document.getElementById('toggleText').innerHTML = `Already have an account? <span onclick="toggleAuthModeState()">Sign In</span>`;
            } else {
                document.getElementById('authTitle').textContent = "Welcome Back";
                document.getElementById('phoneGroupField').style.display = "none";
                document.getElementById('authBtn').textContent = "Sign In Profile";
                document.getElementById('toggleText').innerHTML = `Don't have an account? <span onclick="toggleAuthModeState()">Sign Up</span>`;
            }
        }

        function handleAuthenticationSubmit(e) {
            e.preventDefault();
            const errBlock = document.getElementById('errorBlock');
            errBlock.style.display = 'none';

            const payload = {
                username: document.getElementById('authUsernameInput').value.trim(),
                phone: document.getElementById('authPhoneInput').value.trim(),
                isSignUp: currentAuthIsSignUp
            };

            fetch('/api/auth', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) window.location.reload();
                else { errBlock.textContent = data.error; errBlock.style.display = "block"; }
            });
        }

        function switchTab(viewId) {
            document.querySelectorAll('.view-section').forEach(v => v.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');
            if(event) event.currentTarget.classList.add('active');
        }

        function selectMatchPartner(name, icon) {
            selectedPartnerName = name;
            document.getElementById('activeChatPartnerLabel').textContent = name;
            document.getElementById('partnerAvatarHeader').innerHTML = icon;
            document.getElementById('partnerGreetingMsg').textContent = `Hey there, I'm ${name}. I've been looking at your profile layout all day... say something to me! 😉`;
            switchTab('chat-view');
        }

        function sendChatMessageRoute() {
            const input = document.getElementById('userInput');
            const text = input.value.trim();
            if(!text) return;

            appendMessageContainer(text, 'user-msg');
            input.value = "";
            document.getElementById('typingIndicator').style.display = 'flex';

            fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messageText: text, partnerName: selectedPartnerName })
            })
            .then(res => res.json())
            .then(data => {
                document.getElementById('typingIndicator').style.display = 'none';
                if(data.locked) document.getElementById('payModal').style.display = 'flex';
                else appendMessageContainer(data.reply, 'ai-msg');
            })
            .catch(() => { document.getElementById('typingIndicator').style.display = 'none'; document.getElementById('payModal').style.display = 'flex'; });
        }

        function appendMessageContainer(text, className) {
            const msgDiv = document.createElement('div');
            msgDiv.className = `msg ${className}`;
            msgDiv.textContent = text;
            const box = document.getElementById('chatBox');
            box.insertBefore(msgDiv, document.getElementById('typingIndicator'));
            box.scrollTop = box.scrollHeight;
        }

        function executePesapalCheckoutFlow() {
            const phoneInput = document.getElementById('payPhone').value;
            alert("STK Push successfully requested!\n\nCheck your mobile phone (" + phoneInput + ") right now. A popup menu will appear. Please enter your M-Pesa PIN immediately to complete your Ksh 250 payment.");

            fetch('/api/pay-unlock', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ amount: "250.00", phone: phoneInput })
            })
            .then(res => res.json())
            .then(data => {
                if(data.redirectUrl) window.location.href = data.redirectUrl;
                else alert("STK request timed out. Please check network line.");
            });
        }
    </script>
</body>
</html>
