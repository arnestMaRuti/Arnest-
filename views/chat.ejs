<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SoulAI - Deep Connections</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --accent-pink: #ff477e;
            --accent-hover: #ff1a5c;
            --chat-bg: #0f1016;
            --card-dark: #171923;
            --text-light: #ffffff;
            --text-muted: #94a3b8;
        }
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
        }
        body { 
            background-color: var(--chat-bg); 
            color: var(--text-light); 
            display: flex; 
            flex-direction: column; 
            height: 100vh; 
        }
        /* Top Navigation Header bar */
        .top-bar { 
            padding: 1rem; 
            background: var(--card-dark); 
            display: flex; 
            align-items: center; 
            gap: 1rem; 
            border-bottom: 1px solid rgba(255,255,255,0.05); 
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }
        .avatar { 
            width: 45px; 
            height: 45px; 
            border-radius: 50%; 
            background: linear-gradient(135deg, #ff758f, #ff477e); 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 1.4rem; 
            box-shadow: 0 0 10px rgba(255, 71, 126, 0.4);
        }
        .status-container {
            display: flex;
            flex-direction: column;
        }
        .status-container h4 {
            font-size: 1rem;
            font-weight: 600;
        }
        .status-dot { 
            width: 8px; 
            height: 8px; 
            background: #2ecc71; 
            border-radius: 50%; 
            display: inline-block;
            margin-right: 4px;
        }
        .status-text {
            font-size: 0.75rem; 
            color: var(--text-muted);
            display: flex;
            align-items: center;
        }
        /* Chat Feed Box Containers */
        .chat-area { 
            flex: 1; 
            padding: 1.5rem; 
            overflow-y: auto; 
            display: flex; 
            flex-direction: column; 
            gap: 1rem; 
            background: radial-gradient(circle at top, #141622 0%, var(--chat-bg) 100%);
        }
        .msg { 
            max-width: 80%; 
            padding: 0.85rem 1.15rem; 
            border-radius: 20px; 
            line-height: 1.45; 
            font-size: 0.95rem; 
            word-wrap: break-word;
            animation: fadeIn 0.3s ease-in-out;
        }
        .user-msg { 
            background: var(--accent-pink); 
            color: white;
            align-self: flex-end; 
            border-bottom-right-radius: 4px; 
        }
        .ai-msg { 
            background: var(--card-dark); 
            color: #f1f5f9;
            align-self: flex-start; 
            border-bottom-left-radius: 4px; 
            border: 1px solid rgba(255,255,255,0.05); 
        }
        /* Typing indicator layout block */
        .typing-indicator {
            display: none;
            background: var(--card-dark);
            align-self: flex-start;
            padding: 0.85rem 1.15rem;
            border-radius: 20px;
            border-bottom-left-radius: 4px;
            gap: 4px;
        }
        .typing-dot {
            width: 6px;
            height: 6px;
            background: var(--text-muted);
            border-radius: 50%;
            animation: bounce 1.4s infinite ease-in-out both;
        }
        .typing-dot:nth-child(1) { animation-delay: -0.32s; }
        .typing-dot:nth-child(2) { animation-delay: -0.16s; }

        /* Fixed Footer Input Controls */
        .input-bar { 
            padding: 1rem; 
            background: var(--card-dark); 
            display: flex; 
            gap: 0.75rem; 
            align-items: center;
            border-top: 1px solid rgba(255,255,255,0.05);
        }
        .input-bar input { 
            flex: 1; 
            padding: 0.85rem 1.25rem; 
            border-radius: 25px; 
            border: 1px solid rgba(255,255,255,0.1); 
            background: #222533; 
            color: white; 
            outline: none; 
            font-size: 1rem;
            transition: border 0.2s ease;
        }
        .input-bar input:focus {
            border-color: var(--accent-pink);
        }
        .btn-send { 
            background: var(--accent-pink); 
            border: none; 
            width: 45px; 
            height: 45px; 
            border-radius: 50%; 
            color: white; 
            cursor: pointer; 
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            transition: background 0.2s ease;
        }
        .btn-send:hover { 
            background: var(--accent-hover); 
        }

        /* Pesapal Paywall Modal Windows overlay styling */
        .pay-modal { 
            display: none; 
            position: fixed; 
            top: 0; 
            left: 0; 
            width: 100%; 
            height: 100%; 
            background: rgba(10, 11, 18, 0.95); 
            justify-content: center; 
            align-items: center; 
            padding: 1.5rem; 
            z-index: 999<!DOCTYPE html>
