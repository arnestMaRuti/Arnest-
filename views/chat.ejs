<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SoulAI - Deep Connections</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --accent-pink: #ff477e;
            --accent-hover: #ff1a5c;
            --chat-bg: #0f1016;
            --card-dark: #171923;
            --text-light: #ffffff;
            --text-muted: #94a3b8;
        }
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
        }
        body { 
            background-color: var(--chat-bg); 
            color: var(--text-light); 
            display: flex; 
            flex-direction: column; 
            height: 100vh; 
        }
        .top-bar { 
            padding: 1rem; 
            background: var(--card-dark); 
            display: flex; 
            align-items: center; 
            gap: 1rem; 
            border-bottom: 1px solid rgba(255,255,255,0.05); 
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }
        .avatar { 
            width: 45px; 
            height: 45px; 
            border-radius: 50%; 
            background: linear-gradient(135deg, #ff758f, #ff477e); 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 1.4rem; 
            box-shadow: 0 0 10px rgba(255, 71, 126, 0.4);
        }
        .status-container { display: flex; flex-direction: column; }
        .status-container h4 { font-size: 1rem; font-weight: 600; }
        .status-dot { width: 8px; height: 8px; background: #2ecc71; border-radius: 50%; display: inline-block; margin-right: 4px; }
        .status-text { font-size: 0.75rem; color: var(--text-muted); display: flex; align-items: center; }
        .chat-area { 
            flex: 1; 
            padding: 1.5rem; 
            overflow-y: auto; 
            display: flex; 
            flex-direction: column; 
            gap: 1rem; 
            background: radial-gradient(circle at top, #141622 0%, var(--chat-bg) 100%);
        }
        .msg { max-width: 80%; padding: 0.85rem 1.15rem; border-radius: 20px; line-height: 1.45; font-size: 0.95rem; word-wrap: break-word; animation: fadeIn 0.3s ease-in-out; }
        .user-msg { background: var(--accent-pink); color: white; align-self: flex-end; border-bottom-right-radius: 4px; }
        .ai-msg { background: var(--card-dark); color: #f1f5f9; align-self: flex-start; border-bottom-left-radius: 4px; border: 1px solid rgba(255,255,255,0.05); }
        .typing-indicator { display: none; background: var(--card-dark); align-self: flex-start; padding: 0.85rem 1.15rem; border-radius: 20px; border-bottom-left-radius: 4px; gap: 4px; }
        .typing-dot { width: 6px; height: 6px; background: var(--text-muted); border-radius: 50%; animation: bounce 1.4s infinite ease-in-out both; }
        .typing-dot:nth-child(1) { animation-delay: -0.32s; }
        .typing-dot:nth-child(2) { animation-delay: -0.16s; }
        .input-bar { padding: 1rem; background: var(--card-dark); display: flex; gap: 0.75rem; align-items: center; border-top: 1px solid rgba(255,255,255,0.05); }
        .input-bar input { flex: 1; padding: 0.85rem 1.25rem; border-radius: 25px; border: 1px solid rgba(255,255,255,0.1); background: #222533; color: white; outline: none; font-size: 1rem; }
        .btn-send { background: var(--accent-pink); border: none; width: 45px; height: 45px; border-radius: 50%; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
        .pay-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(10, 11, 18, 0.95); justify-content: center; align-items: center; padding: 1.5rem; z-index: 999; }
        .modal-content { background: var(--card-dark); padding: 2.2rem; border-radius: 24px; text-align: center; max-width: 400px; border: 1px solid rgba(255, 71, 126, 0.2); }
        .modal-content i { font-size: 3.5rem; color: var(--accent-pink); margin-bottom: 1.25rem; }
        .btn-pay { background: linear-gradient(135deg, #2ecc71, #27ae60); color: white; padding: 1rem 2rem; border: none; border-radius: 25px; font-weight: bold; width: 100%; cursor: pointer; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes bounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1.0); } }
    </style>
</head>
<body>

    <div class="top-bar">
        <div class="avatar"><i class="fa-solid fa-venus"></i></div>
        <div class="status-container">
            <h4>Clara</h4>
            <span class="status-text"><span class="status-dot"></span>Online & Listening</span>
        </div>
    </div>

    <div class="chat-area" id="chatBox">
        <div class="msg ai-msg">Hey there... I'm so glad you found me. Tell me, how are you honestly holding up today? 😊</div>
        <div class="typing-indicator" id="typingIndicator">
            <div class="typing-dot"></div>
            <div class="typing-dot"></div>
            <div class="typing-dot"></div>
        </div>
    </div>

    <div class="input-bar">
        <input type="text" id="userInput" placeholder="Type what you're feeling..." onkeypress="handleKeyPress(event)">
        <button class="btn-send" onclick="sendChatMessage()"><i class="fa-solid fa-paper-plane"></i></button>
    </div>

    <div class="pay-modal" id="payModal">
        <div class="modal-content">
            <i class="fa-solid fa-heart-crack"></i>
            <h3>Clara's Chat is Locked</h3>
            <p style="color: var(--text-muted); margin-top: 0.5rem;">Unlock endless premium emotional responses via Pesapal securely.</p>
            <button class="btn-pay" onclick="triggerPesapalRoute()">Unlock Conversations (Ksh 150)</button>
        </div>
    </div>

    <script>
        // Default fallback system UUID to prevent script parsing crashes
        const CURRENT_USER_ID = "00000000-0000-0000-0000-000000000000";

        const chatBox = document.getElementById('chatBox');
        const indicator = document.getElementById('typingIndicator');

        function handleKeyPress(e) { if (e.key === 'Enter') sendChatMessage(); }

        function sendChatMessage() {
            const input = document.getElementById('userInput');
            const text = input.value.trim();
            if(!text) return;

            appendMessage(text, 'user-msg');
            input.value = "";
            showTyping(true);

            fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: CURRENT_USER_ID, messageText: text })
            })
            .then(res => res.json())
            .then(data => {
                showTyping(false);
                if(data.locked) {
                    document.getElementById('payModal').style.display = 'flex';
                } else if(data.reply) {
                    appendMessage(data.reply, 'ai-msg');
                }
            })
            .catch(err => { showTyping(false); console.error(err); });
        }

        function appendMessage(text, className) {
            const msgDiv = document.createElement('div');
            msgDiv.className = `msg ${className}`;
            msgDiv.textContent = text;
            chatBox.insertBefore(msgDiv, indicator);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        function showTyping(isTyping) { indicator.style.display = isTyping ? 'flex' : 'none'; chatBox.scrollTop = chatBox.scrollHeight; }

        function triggerPesapalRoute() {
            fetch('/api/pay-unlock', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId: CURRENT_USER_ID, amount: "150.00", phone: "0712345678" })
            })
            .then(res => res.json())
            .then(data => { if(data.redirectUrl) window.location.href = data.redirectUrl; });
        }
    </script>
</body>
</html>
